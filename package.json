{
  "name": "json-tree-viewer",
  "displayName": "JSON Tree Viewer",
  "description": "View JSON data in an interactive tree format",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/sagarmetaverse/json-tree-viewer-vscode.git"
  },
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "jsonTreeViewer.openViewer",
        "title": "Open JSON Tree Viewer",
        "category": "JSON Tree"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "jsonTreeViewer.openViewer",
          "when": "editorLangId == json",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "jsonTreeViewer.openViewer",
          "when": "resourceExtname == .json",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.74.0",
    "@types/node": "16.x",
    "@typescript-eslint/eslint-plugin": "^5.45.0",
    "@typescript-eslint/parser": "^5.45.0",
    "eslint": "^8.28.0",
    "typescript": "^4.9.4"
  }
}